# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vella:vella@localhost:5432/vella_ops

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Extraction ────────────────────────────────────────────────────────────────

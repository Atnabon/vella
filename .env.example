# ── Integrations ─────────────────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/quickbooks/callback
PLAID_CLIENT_ID=
PLAID_SECRET=
